		{"id":"e-tts-chaptertts","fromNode":"stage-tts","fromSide":"bottom","toNode":"t-tts","toSide":"top"},
		{"id":"e-paras-flutter","fromNode":"t-paragraphs","fromSide":"bottom","toNode":"display-flutter","toSide":"top","label":"processed_content"},
		{"id":"e-tts-flutter","fromNode":"t-tts","fromSide":"bottom","toNode":"display-flutter","toSide":"top","label":"timings + character_id"},
		{"id":"e-paras-admin","fromNode":"t-paragraphs","fromSide":"bottom","toNode":"display-admin","toSide":"top"},
		{"id":"e-llm-admin","fromNode":"t-llm-paras","fromSide":"bottom","toNode":"display-admin","toSide":"top"},
		{"id":"e-llm-tts-display","fromNode":"t-llm-paras","fromSide":"bottom","toNode":"display-tts","toSide":"top"}
	]
